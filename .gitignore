# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
pytest-cache-files-*/

# Test venv (per CLAUDE.md "Python Tests (meshcore-ha-chat)" — uv-managed,
# rebuildable via `uv venv --python 3.14 .venv && .venv/bin/pip install
# pytest-homeassistant-custom-component`).
.venv/

# Test coverage
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# Node / frontend build cache
node_modules/
.rollup.cache/

# Ignore generic dist/ (Python builds, etc.) but DO track the panel
# bundle — HACS users install the prebuilt artifact and never run npm.
dist/
!custom_components/meshcore_chat/frontend/dist/
!custom_components/meshcore_chat/frontend/dist/**

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

 
# Keep upstream files unchanged (only in original repo)
.github/workflows/validate.yaml
README.md
 
